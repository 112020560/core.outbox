{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.Hosting.Lifetime": "Information"
    }
  },
  "Outbox": {
    "ConnectionString": "",
    "PollingIntervalSeconds": 5,
    "BatchSize": 50,
    "ClaimTimeoutSeconds": 60,
    "MaxRetries": 5
  },
  "RabbitMq": {
    "Uri": "amqp://guest:guest@localhost:5672"
  },
  "Publishers": {
    "CustomerCreated":              { "Exchange": "crm.events",       "RoutingKey": "customer.created" },
    "CustomerUpdated":              { "Exchange": "crm.events",       "RoutingKey": "customer.updated" },
    "ProspectConverted":            { "Exchange": "crm.events",       "RoutingKey": "prospect.converted" },
    "CreditApplicationCreated":     { "Exchange": "crm.events",       "RoutingKey": "credit-application.created" },
    "CreditApplicationSubmitted":   { "Exchange": "crm.events",       "RoutingKey": "credit-application.submitted" },
    "RiskEvaluationCompleted":      { "Exchange": "crm.events",       "RoutingKey": "risk-evaluation.completed" },
    "CreditApplicationApproved":    { "Exchange": "crm.events",       "RoutingKey": "credit-application.approved" },
    "CreditApplicationRejected":    { "Exchange": "crm.events",       "RoutingKey": "credit-application.rejected" },

    "PaymentProcessed":             { "Exchange": "payments.events",  "RoutingKey": "payment.processed" },
    "RevolvingPaymentProcessed":    { "Exchange": "payments.events",  "RoutingKey": "revolving-payment.processed" },
    "PaymentFailed":                { "Exchange": "payments.events",  "RoutingKey": "payment.failed" },
    "PaymentRejected":              { "Exchange": "payments.events",  "RoutingKey": "payment.rejected" },

    "SaleQuoteCreatedEvent":        { "Exchange": "sales.events",     "RoutingKey": "sale-quote.created" },
    "SaleQuoteCancelledEvent":      { "Exchange": "sales.events",     "RoutingKey": "sale-quote.cancelled" },
    "SaleQuoteExpiredEvent":        { "Exchange": "sales.events",     "RoutingKey": "sale-quote.expired" },
    "SaleInvoiceConfirmedEvent":    { "Exchange": "sales.events",     "RoutingKey": "sale-invoice.confirmed" },

    "IProductCreated":              { "Exchange": "catalogs.events",  "RoutingKey": "product.created" },
    "IProductUpdated":              { "Exchange": "catalogs.events",  "RoutingKey": "product.updated" },
    "IProductPriceChanged":         { "Exchange": "catalogs.events",  "RoutingKey": "product.price-changed" },
    "IProductActivated":            { "Exchange": "catalogs.events",  "RoutingKey": "product.activated" },
    "IProductDeactivated":          { "Exchange": "catalogs.events",  "RoutingKey": "product.deactivated" },
    "ICategoryCreated":             { "Exchange": "catalogs.events",  "RoutingKey": "category.created" },
    "IBrandCreated":                { "Exchange": "catalogs.events",  "RoutingKey": "brand.created" },

    "IStockMovementConfirmed":      { "Exchange": "inventory.events", "RoutingKey": "stock-movement.confirmed" },
    "ILowStockDetected":            { "Exchange": "inventory.events", "RoutingKey": "low-stock.detected" },
    "IStockReservationCreated":     { "Exchange": "inventory.events", "RoutingKey": "stock-reservation.created" },
    "IStockReservationReleased":    { "Exchange": "inventory.events", "RoutingKey": "stock-reservation.released" },
    "IPhysicalInventoryCompleted":  { "Exchange": "inventory.events", "RoutingKey": "physical-inventory.completed" },

    "ResultadoFacturaElectronica":        { "Exchange": "einvoice.events", "RoutingKey": "einvoice.result" },
    "ElectronicDocumentProcessedEvent":   { "Exchange": "einvoice.events", "RoutingKey": "einvoice.document-processed" },
    "FacturaElectronicaContract":         { "Exchange": "einvoice.events", "RoutingKey": "einvoice.factura" },
    "NotaCreditoElectronicaContract":     { "Exchange": "einvoice.events", "RoutingKey": "einvoice.nota-credito" }
  }
}
